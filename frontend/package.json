{
  "name": "adastat-frontend",
  "description": "AdaStat Cardano Blockchain Explorer - frontend",
  "version": "2.0.0",
  "author": "AdaStat Team <info@adastat.net> (https://adastat.net/)",
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:preprod": "vite --mode preprod",
    "dev:preview": "vite --mode preview",
    "dev-force": "vite --force",
    "dev-force:preprod": "vite --force --mode preprod",
    "dev-force:preview": "vite --force --mode preview",
    "build": "run-p type-check \"build-only {@}\" --",
    "build:preprod": "run-p type-check \"build-only:preprod {@}\" --",
    "build:preview": "run-p type-check \"build-only:preview {@}\" --",
    "preview": "vite preview",
    "preview:preprod": "vite preview --mode preprod",
    "preview:preview": "vite preview --mode preview",
    "build-only": "vite build",
    "build-only:preprod": "vite build --mode preprod",
    "build-only:preview": "vite build --mode preview",
    "type-check": "vue-tsc --build",
    "lint": "eslint . --fix",
    "format": "prettier --write src/"
  },
  "dependencies": {
    "chart.js": "^4.5.1",
    "countup.js": "^2.9.0",
    "d3-hierarchy": "^3.1.2",
    "katex": "^0.16.27",
    "matter-js": "^0.20.0",
    "vue": "^3.5.25",
    "vue-echarts": "^7.0.3",
    "vue-router": "^4.6.3"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.1.17",
    "@trivago/prettier-plugin-sort-imports": "^5.2.2",
    "@tsconfig/node22": "^22.0.5",
    "@types/d3-hierarchy": "^3.1.7",
    "@types/matter-js": "^0.19.8",
    "@types/node": "^22.19.1",
    "@vitejs/plugin-vue": "^6.0.2",
    "@vitejs/plugin-vue-jsx": "^5.1.2",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.6.0",
    "@vue/tsconfig": "^0.7.0",
    "eslint": "^9.39.1",
    "eslint-plugin-vue": "~10.0.1",
    "jiti": "^2.6.1",
    "lightningcss": "^1.30.2",
    "npm-run-all2": "^7.0.2",
    "prettier": "3.5.3",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "svgo": "^3.3.2",
    "tailwindcss": "^4.1.17",
    "terser": "^5.44.1",
    "typescript": "~5.8.3",
    "vite": "^7.2.4",
    "vite-plugin-minify": "^2.1.0",
    "vite-plugin-vue-devtools": "^8.0.5",
    "vue-tsc": "^2.2.12"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@tailwindcss/oxide",
      "esbuild",
      "vue-demi"
    ]
  }
}
