{
  "name": "adastat-backend",
  "description": "AdaStat Cardano Blockchain Explorer - backend",
  "version": "2.0.0",
  "author": "AdaStat Team <info@adastat.net> (https://adastat.net/)",
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "prod": "NODE_ENV=production tsx --env-file=.env index.ts",
    "debug": "LOG_LEVEL=debug tsx --env-file=.env index.ts",
    "trace": "LOG_LEVEL=trace tsx --env-file=.env index.ts",
    "watch": "LOG_LEVEL=debug tsx watch --env-file=.env index.ts --clear-screen=false",
    "build": "tsup index.ts --format esm --clean",
    "start": "NODE_ENV=production node --env-file=.env dist/index.js",
    "lint": "eslint . --fix",
    "format": "prettier --write ./lib/**/*.ts",
    "test": "vitest run tests/unit",
    "test:integration": "vitest run --env-file=.env tests/integration"
  },
  "dependencies": {
    "@dicebear/collection": "^9.4.0",
    "@dicebear/core": "^9.2.4",
    "@fastify/websocket": "^11.2.0",
    "axios": "^1.13.6",
    "bech32": "^2.0.0",
    "blake2b": "^2.1.4",
    "bs58": "^6.0.0",
    "cbor": "^8.1.0",
    "dompurify": "^3.3.1",
    "fastify": "^5.8.2",
    "ipaddr.js": "^2.3.0",
    "jsdom": "^27.4.0",
    "katex": "^0.16.27",
    "markdown-it": "^14.1.0",
    "markdown-it-texmath": "^1.0.0",
    "maxmind": "^5.0.3",
    "pg": "^8.16.3",
    "pg-listen": "^1.7.0",
    "pino": "^10.3.1",
    "punycode": "^2.3.1",
    "sharp": "^0.34.5",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/blake2b": "^2.1.3",
    "@types/jsdom": "^28.0.0",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^22.19.13",
    "@types/pg": "^8.16.0",
    "@types/punycode": "^2.1.4",
    "@types/ws": "^8.18.1",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-disable-autofix": "^6.1.1",
    "globals": "^17.3.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ]
  }
}
