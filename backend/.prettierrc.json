{
  "$schema": "https://json.schemastore.org/prettierrc",
  "bracketSameLine": true,
  "arrowParens": "always",
  "semi": false,
  "tabWidth": 2,
  "singleQuote": true,
  "printWidth": 120,
  "trailingComma": "es5",
  "importOrderSeparation": true,
  "importOrderSortSpecifiers": true,
  "importOrderSideEffects": false,
  "plugins": ["@trivago/prettier-plugin-sort-imports"]
}
